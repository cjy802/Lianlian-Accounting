.reset-page {
  min-height: 100vh;
  padding: 56rpx 28rpx 72rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(0, 120, 212, 0.12) 0, rgba(0, 120, 212, 0.03) 28%, transparent 48%),
    linear-gradient(180deg, #f5f7fa 0%, #eef2f7 100%);
}

.reset-hero {
  position: relative;
  overflow: hidden;
  padding: 34rpx 28rpx 40rpx;
  border-radius: 30rpx;
  background:
    linear-gradient(135deg, rgba(250, 253, 255, 0.98), rgba(239, 246, 252, 0.98)),
    linear-gradient(180deg, #ffffff, #eef4fb);
  border: 1rpx solid #d7e3f0;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.08);
}

.reset-badge {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 108, 189, 0.08);
  color: #005a9e;
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.reset-title {
  margin-top: 22rpx;
  font-size: 52rpx;
  font-weight: 700;
  color: #0f172a;
}

.reset-subtitle {
  margin-top: 16rpx;
  color: #4b5f75;
  font-size: 28rpx;
  line-height: 1.7;
}

.reset-card {
  margin-top: 24rpx;
  padding: 32rpx 28rpx 36rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid #dce6f1;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.07);
}

.field-group {
  margin-top: 24rpx;
}

.field-group:first-child {
  margin-top: 0;
}

.field-label {
  margin-bottom: 14rpx;
  color: #36536b;
  font-size: 26rpx;
  font-weight: 600;
}

.field-input {
  width: 100%;
  height: 90rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx solid #cfdbeb;
  color: #111827;
  font-size: 28rpx;
}

.submit-button {
  margin-top: 32rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  background: linear-gradient(180deg, #0f6cbd, #005a9e);
  box-shadow: 0 16rpx 34rpx rgba(15, 108, 189, 0.22);
}
