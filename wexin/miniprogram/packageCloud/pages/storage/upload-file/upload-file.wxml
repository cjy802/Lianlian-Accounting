<view class="app-shell" wx:if="{{session}}">
  <view class="hero">
    <view class="eyebrow">MANUAL ENTRY</view>
    <view class="hero-title">手动录入账单</view>
    <view class="hero-subtitle">
      输入日常开销信息
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-title">账单信息</view>
      <view class="section-desc">填写基础字段即可完成创建</view>
    </view>

    <view class="paper-card form-card">
      <view class="form-item form-item-primary">
        <view class="form-label form-label-primary">商户名称</view>
        <input
          class="form-input form-input-primary"
          placeholder="例如：瑞幸咖啡、滴滴出行、盒马鲜生"
          value="{{form.merchantName}}"
          data-field="merchantName"
          bindinput="handleInput"
        />
      </view>

      <view class="form-item form-item-primary">
        <view class="form-label form-label-primary">账单金额</view>
        <input
          class="form-input form-input-primary"
          type="digit"
          placeholder="请输入金额"
          value="{{form.amount}}"
          data-field="amount"
          bindinput="handleInput"
        />
      </view>

      <view class="form-item">
        <view class="form-label">账单日期</view>
        <picker mode="date" value="{{form.billDate}}" bindchange="handleDateChange">
          <view class="form-input picker-input">{{form.billDate || '请选择账单日期'}}</view>
        </picker>
      </view>

      <view class="form-item">
        <view class="form-label">分类</view>
        <view class="chip-row">
          <view
            wx:for="{{categoryOptions}}"
            wx:key="code"
            class="{{form.categoryCode === item.code ? 'chip-active' : 'chip'}}"
            data-code="{{item.code}}"
            bindtap="handleCategoryChange"
          >
            {{item.label}}
          </view>
          <view class="chip chip-manage" bindtap="openCategoryManager">管理</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section section-submit">
    <button class="button-primary submit-button" bindtap="submitUpload">创建账单并查看结果</button>
  </view>

  <view class="category-modal-mask" wx:if="{{showCategoryManager}}" bindtap="closeCategoryManager">
    <view class="category-modal category-manager-modal" catchtap="noop">
      <view class="category-modal-title">管理分类</view>
      <view class="category-modal-desc">选择一个分类后，可以修改名称或删除它</view>
      <view class="category-manager-list">
        <view
          wx:for="{{categoryOptions}}"
          wx:key="code"
          class="{{selectedCategoryCode === item.code ? 'category-manager-item category-manager-item-active' : 'category-manager-item'}}"
          data-code="{{item.code}}"
          bindtap="selectManagedCategory"
        >
          {{item.label}}
        </view>
      </view>
      <input
        class="form-input category-modal-input"
        placeholder="修改分类名称"
        value="{{categoryEditorName}}"
        bindinput="handleCategoryEditorInput"
      />
      <view class="category-modal-actions category-manager-actions">
        <view class="button-secondary category-modal-btn" bindtap="deleteManagedCategory">删除</view>
        <view class="button-primary category-modal-btn" bindtap="confirmUpdateCategory">保存</view>
      </view>
    </view>
  </view>
</view>
