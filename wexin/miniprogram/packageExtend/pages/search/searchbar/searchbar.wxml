<view class="app-shell" wx:if="{{session}}">
  <view class="section">
    <view class="paper-card">
      <view class="field-label">搜索账单</view>
      <input class="login-input" placeholder="搜索商家、分类、审查状态" bindinput="handleSearch" value="{{keyword}}" />
      <view class="chip-row" style="margin-top: 20rpx;">
        <view class="{{filter === 'all' ? 'chip-active' : 'chip'}}" data-filter="all" bindtap="changeFilter">全部</view>
        <view class="{{filter === 'pending' ? 'chip-active' : 'chip'}}" data-filter="pending" bindtap="changeFilter">待处理</view>
        <view class="{{filter === 'high' ? 'chip-active' : 'chip'}}" data-filter="high" bindtap="changeFilter">高风险</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-title">账单列表</view>
      <view class="section-desc">{{displayBills.length}} 笔结果</view>
    </view>
    <view class="list-gap" wx:if="{{displayBills.length}}">
      <view class="paper-card" wx:for="{{displayBills}}" wx:key="_id" bindtap="openBill" data-id="{{item._id}}">
        <view class="table-row">
          <view class="table-main">
            <view class="table-title">{{item.merchant_name}}</view>
            <view class="table-subtitle">{{item.bill_date}} · {{item.categoryText}} · {{item.reviewText}}</view>
          </view>
          <view class="table-value">{{item.amountText}}</view>
        </view>
        <view class="bill-card-footer">
          <view class="chip-row bill-card-tags">
            <view class="chip">{{item.riskText}}</view>
            <view class="chip" wx:if="{{item.remark}}">{{item.remark}}</view>
          </view>
          <view
            class="bill-delete-button"
            catchtap="deleteBill"
            data-id="{{item._id}}"
            data-merchant="{{item.merchant_name}}"
          >
            删除
          </view>
        </view>
      </view>
    </view>
    <view class="paper-card empty-state" wx:else>暂无匹配账单，换个关键词试试。</view>
  </view>
</view>
