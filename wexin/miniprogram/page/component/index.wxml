<view class="app-shell" wx:if="{{session}}">
  <view class="hero hero-home">
    <view class="hero-topbar">
      <view class="eyebrow">DIGITAL LEDGER</view>
      <view class="hero-gear" bindtap="openSettings">
        <text class="hero-gear-icon">⚙</text>
      </view>
    </view>
    <view class="hero-title">{{session.user.nickname}}，晚上好</view>
    <view class="hero-subtitle">
      本月已归档 {{overview.billCount}} 笔账单，AI 当前标记 {{overview.riskCount}} 笔高风险。
    </view>
    <view class="hero-actions">
      <button class="button-primary" bindtap="goUpload">上传账单</button>
      <button class="button-secondary" bindtap="goHistory">进入历史账单</button>
    </view>
  </view>

  <view class="metric-grid">
    <view class="paper-card">
      <view class="field-label">本月开支</view>
      <view class="field-value amount-text">{{overview.totalAmountText}}</view>
      <view class="section-desc">{{overview.progressText}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-title">快速入口</view>
    </view>
    <view class="nav-grid">
      <view class="nav-tile" bindtap="goUpload">
        <view class="nav-tile-title">上传账单</view>
      </view>
      <view class="nav-tile" bindtap="goHistory">
        <view class="nav-tile-title">历史账单</view>
      </view>
      <view class="nav-tile" bindtap="goAnalytics">
        <view class="nav-tile-title">统计分析</view>
      </view>
      <view class="nav-tile" bindtap="goAiConsult">
        <view class="nav-tile-title">AI咨询</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-title">最近账单</view>
    </view>
    <view class="list-gap">
      <view
        class="paper-card"
        wx:for="{{overview.recentBills}}"
        wx:key="_id"
        bindtap="openBill"
        data-id="{{item._id}}"
      >
        <view class="table-row">
          <view class="table-main">
            <view class="table-title">{{item.merchant_name}}</view>
            <view class="table-subtitle">{{item.bill_date}} · {{item.categoryText}} · {{item.reviewText}}</view>
          </view>
          <view class="table-value">{{item.amountText}}</view>
        </view>
        <view class="chip-row">
          <view class="chip">{{item.riskText}}</view>
          <view class="chip">{{item.reviewSummary}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="settings-mask" wx:if="{{settingsVisible}}" bindtap="closeSettings">
    <view class="settings-panel" catchtap="noop">
      <view class="settings-header">
        <view class="settings-header-main">
          <view class="settings-title">账户设置</view>
          <view class="settings-subtitle">支持密码修改、AI API 配置和清除记录</view>
        </view>
        <view class="settings-close" bindtap="closeSettings">关闭</view>
      </view>

      <view class="settings-tabs">
        <view
          class="settings-tab {{settingsMode === 'profile' ? 'settings-tab-active' : ''}}"
          data-mode="profile"
          bindtap="switchSettingsMode"
        >
          修改名称
        </view>
        <view
          class="settings-tab {{settingsMode === 'password' ? 'settings-tab-active' : ''}}"
          data-mode="password"
          bindtap="switchSettingsMode"
        >
          密码修改
        </view>
        <view
          class="settings-tab {{settingsMode === 'api' ? 'settings-tab-active' : ''}}"
          data-mode="api"
          bindtap="switchSettingsMode"
        >
          API接口配置
        </view>
        <view
          class="settings-tab {{settingsMode === 'cleanup' ? 'settings-tab-active' : ''}}"
          data-mode="cleanup"
          bindtap="switchSettingsMode"
        >
          清除记录
        </view>
      </view>

      <view class="settings-content" wx:if="{{settingsMode === 'profile'}}">
        <view class="field-stack">
          <view class="field-card">
            <view class="field-label">显示名称</view>
            <input
              class="settings-input"
              value="{{settingsForm.displayName}}"
              data-field="displayName"
              bindinput="handleSettingInput"
              maxlength="20"
              placeholder="请输入新的名称"
            />
          </view>
        </view>
        <view class="settings-tip">修改后会同步更新首页问候语和当前账号显示名称。</view>
        <button class="button-primary settings-submit" loading="{{savingProfile}}" bindtap="saveProfileSettings">
          保存名称
        </button>
      </view>

      <view class="settings-content" wx:if="{{settingsMode === 'password'}}">
        <view class="field-stack">
          <view class="field-card">
            <view class="field-label">当前密码</view>
            <input
              class="settings-input"
              password
              value="{{settingsForm.currentPassword}}"
              data-field="currentPassword"
              bindinput="handleSettingInput"
              placeholder="请输入当前密码"
            />
          </view>
          <view class="field-card">
            <view class="field-label">新密码</view>
            <input
              class="settings-input"
              password
              value="{{settingsForm.newPassword}}"
              data-field="newPassword"
              bindinput="handleSettingInput"
              placeholder="至少 6 位"
            />
          </view>
          <view class="field-card">
            <view class="field-label">确认新密码</view>
            <input
              class="settings-input"
              password
              value="{{settingsForm.confirmPassword}}"
              data-field="confirmPassword"
              bindinput="handleSettingInput"
              placeholder="请再次输入新密码"
            />
          </view>
        </view>
        <button class="button-primary settings-submit" loading="{{savingPassword}}" bindtap="savePasswordSettings">
          保存密码
        </button>
      </view>

      <view class="settings-content" wx:if="{{settingsMode === 'api'}}">
        <view class="field-stack">
          <view class="field-card">
            <view class="field-label">API地址</view>
            <input
              class="settings-input"
              value="{{settingsForm.apiBaseUrl}}"
              data-field="apiBaseUrl"
              bindinput="handleSettingInput"
              placeholder="https://open.bigmodel.cn/api/paas/v4"
            />
          </view>
          <view class="field-card">
            <view class="field-label">接口路径</view>
            <input
              class="settings-input"
              value="{{settingsForm.apiPath}}"
              data-field="apiPath"
              bindinput="handleSettingInput"
              placeholder="/chat/completions"
            />
          </view>
          <view class="field-card">
            <view class="field-label">API Token</view>
            <input
              class="settings-input"
              value="{{settingsForm.apiToken}}"
              data-field="apiToken"
              bindinput="handleSettingInput"
              placeholder="请输入接口凭证"
            />
          </view>
          <view class="field-card">
            <view class="field-label">模型名称</view>
            <input
              class="settings-input"
              value="{{settingsForm.apiModel}}"
              data-field="apiModel"
              bindinput="handleSettingInput"
              placeholder="glm-4-flash"
            />
          </view>
          <view class="field-card">
            <view class="field-label">请求超时（毫秒）</view>
            <input
              class="settings-input"
              type="number"
              value="{{settingsForm.apiTimeout}}"
              data-field="apiTimeout"
              bindinput="handleSettingInput"
              placeholder="1000 - 120000"
            />
          </view>
        </view>
        <view class="settings-tip">AI 咨询页面会使用这里的 API 配置进行处理。</view>
        <button class="button-primary settings-submit" loading="{{savingApiConfig}}" bindtap="saveApiConfig">
          保存 AI API 配置
        </button>
      </view>

      <view class="settings-content" wx:if="{{settingsMode === 'cleanup'}}">
        <view class="settings-warning">
          <view class="settings-warning-title">清除范围</view>
          <view class="settings-warning-text">将删除当前账户的账单、识别结果和通知记录，操作不可恢复。</view>
        </view>
        <button class="button-danger settings-submit" loading="{{clearingRecords}}" bindtap="confirmClearRecords">
          清除记录
        </button>
      </view>

      <button class="button-ghost settings-logout" bindtap="handleLogout">退出登录</button>
    </view>
  </view>
</view>
