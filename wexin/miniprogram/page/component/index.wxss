.hero-home {
  padding-top: 36rpx;
}

.hero-topbar {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 12rpx;
}

.hero-gear {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  min-width: 48rpx;
  height: 48rpx;
  min-height: 48rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #0a66b2;
  border: 1rpx solid rgba(15, 108, 189, 0.14);
  color: #fdfdfd;
  font-size: 48rpx;
  line-height: 1;
}

.hero-gear-icon {
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 600;
}

.paper-card .chip:last-child {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.metric-grid {
  grid-template-columns: minmax(0, 1fr);
}

.settings-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 99;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 23, 42, 0.34);
}

.settings-panel {
  width: 100%;
  max-height: 86vh;
  overflow-y: auto;
  padding: 32rpx 28rpx calc(env(safe-area-inset-bottom) + 28rpx);
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -18rpx 42rpx rgba(15, 23, 42, 0.12);
}

.settings-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.settings-header-main {
  flex: 1;
}

.settings-title {
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 700;
}

.settings-subtitle {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 24rpx;
}

.settings-close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 92rpx;
  min-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #cfdbeb;
  color: #36536b;
  font-size: 24rpx;
}

.settings-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.settings-tab {
  flex: 1 1 0;
  min-width: 148rpx;
  min-height: 68rpx;
  padding: 0 12rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #d6e2ee;
  color: #516274;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 68rpx;
  text-align: center;
}

.settings-tab-active {
  background: linear-gradient(180deg, #0f6cbd, #0a5797);
  border-color: rgba(15, 108, 189, 0.22);
  color: #ffffff;
  box-shadow: 0 10rpx 20rpx rgba(15, 108, 189, 0.22);
}

.settings-content {
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(248, 251, 255, 0.95);
  border: 1rpx solid #dce6f1;
}

.settings-input {
  width: 100%;
  height: 84rpx;
  margin-top: 14rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #cfdbeb;
}

.settings-submit {
  width: 100%;
  margin-top: 22rpx;
}

.settings-tip {
  margin-top: 16rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.5;
}

.settings-warning {
  padding: 20rpx;
  border-radius: 16rpx;
  background: #fff6f5;
  border: 1rpx solid #f3c5c0;
}

.settings-warning-title {
  color: #9f1239;
  font-size: 28rpx;
  font-weight: 700;
}

.settings-warning-text {
  margin-top: 10rpx;
  color: #7f1d1d;
  font-size: 24rpx;
  line-height: 1.55;
}

.settings-logout {
  width: 100%;
  margin-top: 20rpx;
}
