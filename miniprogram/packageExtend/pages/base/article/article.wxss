.consult-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 20rpx 20rpx calc(env(safe-area-inset-bottom) + 20rpx);
  box-sizing: border-box;
}

.consult-header {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 10rpx 6rpx 16rpx;
}

.consult-title {
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 700;
}

.consult-back {
  min-height: 52rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid #cfdbeb;
  background: #ffffff;
  color: #36536b;
  font-size: 22rpx;
  line-height: 52rpx;
}

.consult-messages {
  flex: 1;
  min-height: 0;
  padding: 12rpx 6rpx;
}

.consult-message {
  display: flex;
  margin-bottom: 18rpx;
}

.consult-message-ai {
  justify-content: flex-start;
}

.consult-message-user {
  justify-content: flex-end;
}

.consult-bubble {
  max-width: 86%;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
  border: 1rpx solid #dce6f1;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
}

.consult-stream-cursor {
  display: inline-block;
  margin-left: 6rpx;
  color: #0f6cbd;
  font-weight: 700;
  animation: consultCursorBlink 1s steps(2, start) infinite;
}

.consult-message-ai .consult-bubble {
  background: rgba(255, 255, 255, 0.96);
  color: #0f172a;
}

.consult-message-user .consult-bubble {
  background: linear-gradient(180deg, #0f6cbd, #0b5ea6);
  color: #ffffff;
  border-color: rgba(15, 108, 189, 0.2);
}

.consult-loading {
  display: flex;
  justify-content: flex-start;
  padding-bottom: 16rpx;
}

.consult-loading-text {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(15, 108, 189, 0.1);
  color: #0f6cbd;
  font-size: 22rpx;
}

.consult-input-bar {
  flex-shrink: 0;
}

.consult-input-shell {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 12rpx 12rpx 14rpx;
  border-radius: 22rpx;
  border: 1rpx solid #dce6f1;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 20rpx rgba(15, 23, 42, 0.05);
}

.consult-input {
  flex: 1;
  min-height: 76rpx;
  max-height: 240rpx;
  padding: 12rpx 6rpx 12rpx 12rpx;
  color: #0f172a;
  font-size: 26rpx;
  line-height: 1.5;
}

.consult-send-btn {
  width: 48rpx;
  min-width: 48rpx;
  height: 48rpx;
  min-height: 48rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  flex: 0 0 40rpx;
  border: none;
  overflow: hidden;
  background: linear-gradient(180deg, #0f6cbd, #0b5ea6);
  box-shadow: 0 10rpx 18rpx rgba(15, 108, 189, 0.24);
}

.consult-send-btn-disabled {
  opacity: 0.65;
}

.consult-send-icon {
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1;
  transform: translateX(1rpx) rotate(-18deg);
}

@keyframes consultCursorBlink {
  0%,
  49% {
    opacity: 1;
  }

  50%,
  100% {
    opacity: 0;
  }
}
