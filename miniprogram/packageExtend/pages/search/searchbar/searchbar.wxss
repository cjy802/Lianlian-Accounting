.paper-card .login-input {
  margin-top: 16rpx;
}

.bill-card-footer {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.bill-card-tags {
  flex: 1;
  min-width: 0;
}

.bill-delete-button {
  flex-shrink: 0;
  min-width: 112rpx;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(217, 48, 37, 0.22);
  background: #fff3f1;
  color: #d93025;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 56rpx;
  text-align: center;
  box-sizing: border-box;
}
