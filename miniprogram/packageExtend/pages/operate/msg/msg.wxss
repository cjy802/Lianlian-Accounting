.summary-amount {
  color: #0f6cbd;
  font-size: 40rpx;
}

.request-status-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.request-status-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.request-status-label {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 700;
}

.request-status-badge {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.request-status-badge.idle {
  background: rgba(148, 163, 184, 0.16);
  color: #475569;
}

.request-status-badge.loading {
  background: rgba(15, 108, 189, 0.12);
  color: #0f6cbd;
}

.request-status-badge.success {
  background: rgba(22, 163, 74, 0.14);
  color: #15803d;
}

.request-status-badge.error {
  background: rgba(220, 38, 38, 0.12);
  color: #b91c1c;
}

.request-status-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.request-status-key {
  flex-shrink: 0;
  width: 160rpx;
  color: #64748b;
  font-size: 24rpx;
}

.request-status-value {
  flex: 1;
  color: #0f172a;
  font-size: 24rpx;
  line-height: 1.7;
  text-align: right;
}

.request-status-break {
  word-break: break-all;
}

.request-status-error {
  color: #b91c1c;
}

.review-loading-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 280rpx;
  text-align: center;
}

.loading-spinner {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  border: 6rpx solid #d5e4f3;
  border-top-color: #0f6cbd;
  animation: review-spin 0.9s linear infinite;
}

.loading-title {
  margin-top: 24rpx;
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 700;
}

.loading-subtitle {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.7;
}

.review-error-card {
  background: linear-gradient(180deg, rgba(255, 245, 245, 0.96), rgba(255, 255, 255, 0.96));
}

.review-error-actions {
  margin-top: 20rpx;
}

.review-action-btn {
  min-width: 280rpx;
}

.review-content-card,
.review-empty-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.review-highlight {
  margin-bottom: 4rpx;
}

.review-block-title {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 700;
}

.review-block-text {
  margin-top: 10rpx;
  color: #475569;
  font-size: 26rpx;
  line-height: 1.8;
  white-space: pre-line;
}

.review-list-row {
  padding: 12rpx 0;
}

@keyframes review-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
