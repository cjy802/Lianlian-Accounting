<view class="app-shell" wx:if="{{detail}}">
  <view class="hero">
    <view class="eyebrow">AI BILL REVIEW</view>
    <view class="hero-title">
      {{aiRequestState === 'loading'
        ? 'AI 正在真实评审账单'
        : (aiRequestState === 'error'
          ? 'AI 调用失败'
          : (aiRequestState === 'success' ? 'AI 真实评审结果' : '尚未拿到真实 AI 结果'))}}
    </view>
    <view class="hero-subtitle">
      {{aiRequestState === 'loading'
        ? reviewLoadingText
        : (aiRequestState === 'error'
          ? reviewError
          : (aiRequestState === 'success'
            ? (detail.review.hero_summary || detail.review.review_summary)
            : '当前页面还没有拿到大模型真实返回结果。'))}}
    </view>
    <view class="hero-actions">
      <button class="button-primary" bindtap="goDetail">查看账单详情</button>
      <button class="button-secondary" bindtap="backHome">返回首页</button>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-title">账单概览</view>
      <view class="section-desc">{{detail.bill.categoryText}}</view>
    </view>
    <view class="paper-card field-stack">
      <view class="field-card">
        <view class="field-label">商户名称</view>
        <view class="field-value">{{detail.bill.merchant_name || '未填写'}}</view>
      </view>
      <view class="field-card">
        <view class="field-label">账单金额</view>
        <view class="field-value amount-text summary-amount">{{detail.bill.amountText}}</view>
      </view>
      <view class="field-card">
        <view class="field-label">账单日期</view>
        <view class="field-value">{{detail.bill.bill_date || '--'}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-title">AI 调用状态</view>
      <view class="section-desc">这里只显示真实请求状态</view>
    </view>
    <view class="paper-card request-status-card">
      <view class="request-status-head">
        <view class="request-status-label">当前状态</view>
        <view class="request-status-badge {{aiRequestState}}">
          {{aiRequestState === 'loading'
            ? '调用中'
            : (aiRequestState === 'error'
              ? '调用失败'
              : (aiRequestState === 'success' ? '调用成功' : '未返回'))}}
        </view>
      </view>

      <view class="request-status-row">
        <view class="request-status-key">接口地址</view>
        <view class="request-status-value request-status-break">{{aiRequestMeta.requestUrl || '--'}}</view>
      </view>
      <view class="request-status-row">
        <view class="request-status-key">调用模型</view>
        <view class="request-status-value">{{aiRequestMeta.requestModel || '--'}}</view>
      </view>
      <view class="request-status-row">
        <view class="request-status-key">超时设置</view>
        <view class="request-status-value">{{aiRequestMeta.timeoutText}}</view>
      </view>
      <view class="request-status-row">
        <view class="request-status-key">开始时间</view>
        <view class="request-status-value">{{aiRequestMeta.startedAtText}}</view>
      </view>
      <view class="request-status-row">
        <view class="request-status-key">结束时间</view>
        <view class="request-status-value">{{aiRequestMeta.finishedAtText}}</view>
      </view>
      <view class="request-status-row">
        <view class="request-status-key">HTTP 状态</view>
        <view class="request-status-value">{{aiRequestMeta.httpStatusText}}</view>
      </view>
      <view class="request-status-row" wx:if="{{aiRequestMeta.errorText}}">
        <view class="request-status-key">失败原因</view>
        <view class="request-status-value request-status-error">{{aiRequestMeta.errorText}}</view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{reviewing}}">
    <view class="paper-card review-loading-card">
      <view class="loading-spinner"></view>
      <view class="loading-title">AI 正在分析这笔账单</view>
      <view class="loading-subtitle">{{reviewLoadingText}}</view>
    </view>
  </view>

  <view class="section" wx:if="{{aiRequestState === 'error'}}">
    <view class="section-header">
      <view class="section-title">评审失败</view>
      <view class="section-desc">本次没有拿到真实 AI 返回</view>
    </view>
    <view class="paper-card review-error-card">
      <view class="notice-title">AI 评审未完成</view>
      <view class="notice-content">{{reviewError}}</view>
      <view class="inline-actions review-error-actions">
        <button class="button-primary review-action-btn" bindtap="retryAiReview">重新发起真实 AI 评审</button>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-title">AI 评审</view>
      <view class="section-desc">
        {{aiRequestState === 'success'
          ? '以下内容来自本次真实大模型返回'
          : (aiRequestState === 'loading'
            ? '正在等待大模型真实返回'
            : (aiRequestState === 'error' ? '本次真实评审失败' : '尚未拿到真实评审结果'))}}
      </view>
    </view>

    <view class="paper-card review-content-card" wx:if="{{aiRequestState === 'success' && detail.review.review_source === 'AI'}}">
      <view class="notice-card review-highlight" wx:if="{{detail.review.comparison_text}}">
        <view class="notice-title">消费评估</view>
        <view class="notice-content review-block-text">{{detail.review.comparison_text}}</view>
      </view>

      <view class="review-block">
        <view class="review-block-title">评审说明</view>
        <view class="review-block-text">{{detail.review.analysis_text || detail.review.review_summary}}</view>
      </view>

      <view class="divider" wx:if="{{detail.review.review_suggestions.length}}"></view>

      <view class="review-block" wx:if="{{detail.review.review_suggestions.length}}">
        <view class="review-block-title">建议</view>
        <view class="table-row review-list-row" wx:for="{{detail.review.review_suggestions}}" wx:key="*this">
          <view class="table-main">
            <view class="table-title">{{index + 1}}. {{item}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="paper-card review-empty-card" wx:else>
      <view class="review-block-title">暂无真实 AI 结果</view>
      <view class="review-block-text">
        {{aiRequestState === 'loading'
          ? '当前已经向大模型发送请求，请等待返回。'
          : (aiRequestState === 'error'
            ? '本次请求失败，没有生成真实评审内容。'
            : '当前还没有拿到大模型真实返回结果，点击下方按钮可重新发起。')}}
      </view>
      <view class="inline-actions review-error-actions" wx:if="{{!reviewing}}">
        <button class="button-primary review-action-btn" bindtap="retryAiReview">发起真实 AI 评审</button>
      </view>
    </view>
  </view>
</view>
