.form-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 251, 255, 0.98));
  border-color: #d8e3ef;
  box-shadow: 0 14rpx 36rpx rgba(15, 23, 42, 0.06);
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f9fbfe, #f5f8fc);
  border: 1rpx solid #e0e8f2;
}

.form-item-primary {
  padding: 22rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #31445f;
}

.form-label-primary {
  font-size: 30rpx;
  font-weight: 700;
  color: #19253a;
}

.form-input {
  width: 100%;
  box-sizing: border-box;
  min-height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d4e0ed;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
  color: #1f2a44;
}

.form-input-primary {
  min-height: 96rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.picker-input {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 24rpx;
  color: #34465f;
}

.section-header {
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.section-title {
  letter-spacing: 1rpx;
}

.section-desc {
  line-height: 1.5;
}

.form-card .chip,
.form-card .chip-active,
.chip-manage {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 68rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.form-card .chip {
  background: rgba(255, 255, 255, 0.96);
  color: #36536b;
  border: 1rpx solid #d6e2ee;
}

.form-card .chip-active {
  background: linear-gradient(180deg, #0f6cbd, #0a5da6);
  color: #ffffff;
  box-shadow: 0 10rpx 20rpx rgba(15, 108, 189, 0.18);
}

.chip-manage {
  min-width: 120rpx;
  background: rgba(233, 241, 250, 0.92);
  color: #21496f;
  border: 1rpx solid #c9d9ea;
}

.section-submit {
  margin-top: 30rpx;
}

.submit-button {
  display: flex;
  width: 100%;
  min-height: 90rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.category-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(15, 23, 42, 0.36);
}

.category-modal {
  width: 100%;
  max-width: 560rpx;
  padding: 34rpx 30rpx 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(246, 250, 255, 0.99));
  border: 1rpx solid #dbe6f1;
  box-shadow: 0 24rpx 56rpx rgba(15, 23, 42, 0.16);
}

.category-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2a44;
}

.category-modal-desc {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.5;
}

.category-manager-modal {
  max-width: 620rpx;
}

.category-manager-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.category-manager-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 68rpx;
  padding: 0 24rpx;
  border: 1px solid #d7e4f6;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  font-size: 26rpx;
  font-weight: 600;
  color: #4a5a78;
}

.category-manager-item-active {
  border-color: rgba(15, 108, 189, 0.24);
  background: rgba(15, 108, 189, 0.12);
  color: #0c4f87;
}

.category-modal-input {
  margin-top: 24rpx;
  min-height: 92rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.category-modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.category-modal-btn {
  flex: 1;
  min-width: 0;
}
