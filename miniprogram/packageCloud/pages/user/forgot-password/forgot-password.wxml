<view class="reset-page">
  <view class="reset-hero">
    <view class="reset-badge">PASSWORD RESET</view>
    <view class="reset-title">忘记密码</view>
    <view class="reset-subtitle">输入账号并设置两次新密码，提交后会自动登录回系统。</view>
  </view>

  <view class="reset-card">
    <view class="field-group">
      <view class="field-label">账号</view>
      <input
        class="field-input"
        value="{{account}}"
        placeholder="请输入你的账号"
        bindinput="handleInput"
        data-field="account"
      />
    </view>

    <view class="field-group">
      <view class="field-label">新密码</view>
      <input
        class="field-input"
        value="{{newPassword}}"
        placeholder="请输入至少 6 位的新密码"
        password
        bindinput="handleInput"
        data-field="newPassword"
      />
    </view>

    <view class="field-group">
      <view class="field-label">确认新密码</view>
      <input
        class="field-input"
        value="{{confirmPassword}}"
        placeholder="请再次输入新密码"
        password
        bindinput="handleInput"
        data-field="confirmPassword"
      />
    </view>

    <button class="submit-button" loading="{{loading}}" bindtap="handleSubmit">重置密码并登录</button>
  </view>
</view>
